# === Investment Intelligence Studio — Environment Variables ===

# OpenAI / Azure OpenAI (required for LLM-based agents)
AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
DEPLOY=o4-mini

# FRED — Federal Reserve Economic Data (free key, generous limits)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-key-here

# SEC EDGAR — required user-agent header (use your real email)
SEC_EDGAR_USER_AGENT=InvestmentIntelligenceStudio/1.0 (your-email@example.com)

# Optional: model overrides
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2

# MCP transport: "direct" (in-process, fast) or "stdio" (real JSON-RPC subprocess)
MCP_TRANSPORT=direct

# ── No longer needed (replaced by yfinance — free, no key) ──
# ALPHAVANTAGE_API_KEY  → replaced by yfinance
# FMP_API_KEY           → replaced by yfinance
